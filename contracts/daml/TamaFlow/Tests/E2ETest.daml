module TamaFlow.Tests.E2ETest where

import DA.Time
import Daml.Script

import TamaFlow.Company.CompanyProfile
import TamaFlow.Company.EmployeeRecord
import TamaFlow.JPYC.Asset
import TamaFlow.JPYC.Issuer
import TamaFlow.JPYC.Types (instrumentIdText)
import TamaFlow.Attendance.TimeBlock
import TamaFlow.Attendance.Types (BlockStatus(..))

-- | End-to-end flow test with clear admin/employer separation
testFullFlow : Script ()
testFullFlow = script do
  admin <- allocateParty "Admin"
  employer <- allocateParty "Employer"
  alice <- allocateParty "Alice"
  now <- getTime

  -- Step 1: Admin deploys JPYCIssuer (global token)
  issuerCid <- submit admin do
    createCmd JPYCIssuer with
      admin
      instrumentId = instrumentIdText

  -- Step 2: Employer creates CompanyProfile
  companyCid <- submit employer do
    createCmd CompanyProfile with
      employer
      companyName = "Acme Corp"
      country = "JP"

  -- Step 3: Employer adds employee
  _ <- submit employer do
    exerciseCmd companyCid AddEmployee with
      employee = alice
      displayName = "Alice Smith"
      role = Some "Engineer"

  -- Step 4: Employee checks in (creates TimeBlock)
  _ <- submit alice do
    createCmd TimeBlock with
      employee = alice
      employer
      blockStart = now
      blockEnd = addRelTime now (days 1)
      status = Open
      note = None

  -- Step 5: Employer confirms check-in (skip for now)

  -- Step 6: Admin mints 10,000 JPY to employer
  _ <- submit admin do
    exerciseCmd issuerCid Mint with
      owner = employer
      amount = 10000.0
      observers = []

  -- Step 7: Employer sends JPY to employee
  -- Query employer's JPYC holdings
  employerAssets <- query @JPYCAsset employer
  assertMsg "Employer should have JPYC holdings" (length employerAssets > 0)

  -- Just verify the flow works - actual transfer tested in JPYCTest
  return ()
