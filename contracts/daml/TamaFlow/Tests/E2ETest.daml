module TamaFlow.Tests.E2ETest where

import DA.Time
import Daml.Script

import TamaFlow.Company.CompanyProfile
import TamaFlow.Company.EmployeeRecord
import TamaFlow.JPYC.Asset
import TamaFlow.JPYC.Issuer
import TamaFlow.JPYC.Types (instrumentIdText)
import TamaFlow.Attendance.TimeBlock
import TamaFlow.Attendance.Types (BlockStatus(..))

-- | End-to-end flow test
testFullFlow : Script ()
testFullFlow = script do
  admin <- allocateParty "Admin"
  employer <- allocateParty "Employer"
  alice <- allocateParty "Alice"
  now <- getTime

  -- Step 1: Admin creates company
  companyCid <- submit admin do
    createCmd CompanyProfile with
      admin
      employer
      companyName = "Acme Corp"
      country = "JP"

  -- Step 2: Employer adds employee (employer controls AddEmployee)
  _ <- submit employer do
    exerciseCmd companyCid AddEmployee with
      employee = alice
      displayName = "Alice Smith"
      role = Some "Engineer"

  -- Step 3: Employee lists companies (just verify query works)
  _ <- query @EmployeeRecord alice

  -- Step 4: Employee does 4 time check-ins (1 hour each)
  let h = days 1
  _ <- submit alice do
    createCmd TimeBlock with employee = alice; employer; blockStart = now; blockEnd = addRelTime now h; status = Open; note = None
  _ <- submit alice do
    createCmd TimeBlock with employee = alice; employer; blockStart = addRelTime now h; blockEnd = addRelTime now (h + h); status = Open; note = None
  _ <- submit alice do
    createCmd TimeBlock with employee = alice; employer; blockStart = addRelTime now (h + h); blockEnd = addRelTime now (h + h + h); status = Open; note = None
  _ <- submit alice do
    createCmd TimeBlock with employee = alice; employer; blockStart = addRelTime now (h + h + h); blockEnd = addRelTime now (h + h + h + h); status = Open; note = None

  -- Step 5: Employer mints 100,000 JPYC
  issuerCid <- submit employer do
    createCmd JPYCIssuer with admin = employer; instrumentId = instrumentIdText

  assetCid <- submit employer do
    exerciseCmd issuerCid Mint with owner = employer; amount = 100000.0; observers = []

  -- Step 6: Employer sends 10,000 JPYC to employee
  (paymentCid, _changeCid) <- submit employer do
    exerciseCmd assetCid Split with paymentAmount = 10000.0

  _ <- submit employer do
    exerciseCmd paymentCid TransferAsset with newOwner = alice

  -- Step 7: Employee checks balance (just verify query works)
  _ <- query @JPYCAsset alice

  return ()
