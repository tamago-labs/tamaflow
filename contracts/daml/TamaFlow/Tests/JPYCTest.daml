module TamaFlow.Tests.JPYCTest where

import DA.TextMap as TM
import Daml.Script

import TamaFlow.JPYC.Asset
import TamaFlow.JPYC.Faucet
import TamaFlow.JPYC.Issuer
import TamaFlow.JPYC.Types (instrumentIdText)

testMint : Script ()
testMint = script do
  admin <- allocateParty "Admin"
  alice <- allocateParty "Alice"

  issuerCid <- submit admin do
    createCmd JPYCIssuer with
      admin
      instrumentId = instrumentIdText

  _ <- submit admin do
    exerciseCmd issuerCid Mint with
      owner = alice
      amount = 1000.0
      observers = []

  return ()

testMintToMultiple : Script ()
testMintToMultiple = script do
  admin <- allocateParty "Admin"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"

  issuerCid <- submit admin do
    createCmd JPYCIssuer with
      admin
      instrumentId = instrumentIdText

  _ <- submit admin do
    exerciseCmd issuerCid Mint with
      owner = alice
      amount = 500.0
      observers = []

  _ <- submit admin do
    exerciseCmd issuerCid Mint with
      owner = bob
      amount = 300.0
      observers = []

  return ()

testSplitAndTransfer : Script ()
testSplitAndTransfer = script do
  admin <- allocateParty "Admin"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"

  issuerCid <- submit admin do
    createCmd JPYCIssuer with
      admin
      instrumentId = instrumentIdText

  assetCid <- submit admin do
    exerciseCmd issuerCid Mint with
      owner = alice
      amount = 10000.0
      observers = []

  (paymentCid, _changeCid) <- submit alice do
    exerciseCmd assetCid Split with
      paymentAmount = 1000.0

  _ <- submit alice do
    exerciseCmd paymentCid TransferAsset with
      newOwner = bob

  return ()

testTransfer : Script ()
testTransfer = script do
  admin <- allocateParty "Admin"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"

  issuerCid <- submit admin do
    createCmd JPYCIssuer with
      admin
      instrumentId = instrumentIdText

  assetCid <- submit admin do
    exerciseCmd issuerCid Mint with
      owner = alice
      amount = 500.0
      observers = []

  _ <- submit alice do
    exerciseCmd assetCid TransferAsset with
      newOwner = bob

  return ()

-- Faucet tests: admin exercises Claim on behalf of users
-- (In production, a public party would observe the Faucet)

testFaucetClaim : Script ()
testFaucetClaim = script do
  admin <- allocateParty "Admin"
  public <- allocateParty "Public"
  alice <- allocateParty "Alice"

  faucetCid <- submit admin do
    createCmd Faucet with
      admin
      issuer = admin
      publicObserver = public
      instrumentId = instrumentIdText
      perClaimLimit = 1000.0
      totalClaimed = 0.0
      claims = TM.empty

  -- Admin claims on behalf of Alice (both must authorize)
  _ <- submitMulti [admin, alice] [] do
    exerciseCmd faucetCid Claim with
      claimant = alice
      amount = 500.0

  return ()

testFaucetClaimLimit : Script ()
testFaucetClaimLimit = script do
  admin <- allocateParty "Admin"
  public <- allocateParty "Public"
  alice <- allocateParty "Alice"

  faucetCid <- submit admin do
    createCmd Faucet with
      admin
      issuer = admin
      publicObserver = public
      instrumentId = instrumentIdText
      perClaimLimit = 1000.0
      totalClaimed = 0.0
      claims = TM.empty

  _ <- submitMulti [admin, alice] [] do
    exerciseCmd faucetCid Claim with
      claimant = alice
      amount = 800.0

  -- After Claim, a new Faucet is created. Query for the current one.
  faucets <- query @Faucet admin
  assertMsg "Should have at least one Faucet" (length faucets > 0)

  return ()

testFaucetMultipleUsers : Script ()
testFaucetMultipleUsers = script do
  admin <- allocateParty "Admin"
  public <- allocateParty "Public"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"

  faucetCid <- submit admin do
    createCmd Faucet with
      admin
      issuer = admin
      publicObserver = public
      instrumentId = instrumentIdText
      perClaimLimit = 1000.0
      totalClaimed = 0.0
      claims = TM.empty

  _ <- submitMulti [admin, alice] [] do
    exerciseCmd faucetCid Claim with
      claimant = alice
      amount = 500.0

  _ <- submitMulti [admin, bob] [] do
    exerciseCmd faucetCid Claim with
      claimant = bob
      amount = 700.0

  return ()
