module TamaFlow.Tests.CompanyTest where

import DA.TextMap as TM
import DA.Time
import Daml.Script

import TamaFlow.Company.CompanyProfile
import TamaFlow.Company.EmployeeRecord
import TamaFlow.Company.Types (BlockStatus(..))

-- Company tests

testCreateCompany : Script ()
testCreateCompany = script do
  admin <- allocateParty "Admin"
  employer <- allocateParty "Employer"

  _ <- submit admin do
    createCmd CompanyProfile with
      admin
      employer
      companyName = "Acme Corp"
      country = "JP"

  return ()

testAddEmployee : Script ()
testAddEmployee = script do
  admin <- allocateParty "Admin"
  employer <- allocateParty "Employer"
  alice <- allocateParty "Alice"

  companyCid <- submit admin do
    createCmd CompanyProfile with
      admin
      employer
      companyName = "Acme Corp"
      country = "JP"

  _ <- submit employer do
    exerciseCmd companyCid AddEmployee with
      employee = alice
      displayName = "Alice Smith"
      role = Some "Engineer"

  return ()

testListCompanies : Script ()
testListCompanies = script do
  admin <- allocateParty "Admin"
  employer <- allocateParty "Employer"

  _ <- submit admin do
    createCmd CompanyProfile with
      admin
      employer
      companyName = "Acme Corp"
      country = "JP"

  _ <- submit admin do
    createCmd CompanyProfile with
      admin
      employer
      companyName = "Tech Corp"
      country = "US"

  companies <- query @CompanyProfile admin
  assertMsg "Should have 2 companies" (length companies == 2)

  return ()

testMultipleEmployees : Script ()
testMultipleEmployees = script do
  admin <- allocateParty "Admin"
  employer <- allocateParty "Employer"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"

  companyCid <- submit admin do
    createCmd CompanyProfile with
      admin
      employer
      companyName = "Acme Corp"
      country = "JP"

  _ <- submit employer do
    exerciseCmd companyCid AddEmployee with
      employee = alice
      displayName = "Alice Smith"
      role = Some "Engineer"

  _ <- submit employer do
    exerciseCmd companyCid AddEmployee with
      employee = bob
      displayName = "Bob Jones"
      role = Some "Designer"

  employees <- query @EmployeeRecord employer
  assertMsg "Should have 2 employees" (length employees == 2)

  return ()

-- Attendance tests

testCheckIn : Script ()
testCheckIn = script do
  admin <- allocateParty "Admin"
  employer <- allocateParty "Employer"
  alice <- allocateParty "Alice"
  now <- getTime

  companyCid <- submit admin do
    createCmd CompanyProfile with
      admin
      employer
      companyName = "Acme Corp"
      country = "JP"

  _ <- submit employer do
    exerciseCmd companyCid AddEmployee with
      employee = alice
      displayName = "Alice Smith"
      role = Some "Engineer"

  employees <- query @EmployeeRecord employer
  assertMsg "Should have 1 employee" (length employees == 1)

  -- Just verify check-in works
  return ()

