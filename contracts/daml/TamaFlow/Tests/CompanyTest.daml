module TamaFlow.Tests.CompanyTest where

import DA.Time
import Daml.Script

import TamaFlow.Company.CompanyProfile
import TamaFlow.Company.CompanyRegistry
import TamaFlow.Company.EmployeeRecord

testCreateCompany : Script ()
testCreateCompany = script do
  admin <- allocateParty "Admin"

  registryCid <- submit admin do
    createCmd CompanyRegistry with admin

  _ <- submit admin do
    exerciseCmd registryCid AddCompany with
      employerName = "Alice Corp"
      companyName = "Acme Corp"
      country = "JP"

  return ()

testAddEmployee : Script ()
testAddEmployee = script do
  admin <- allocateParty "Admin"
  alice <- allocateParty "Alice"

  registryCid <- submit admin do
    createCmd CompanyRegistry with admin

  _ <- submit admin do
    exerciseCmd registryCid AddEmployee with
      companyName = "Acme Corp"
      employee = alice
      displayName = "Alice Smith"
      role = Some "Engineer"

  return ()

testListCompanies : Script ()
testListCompanies = script do
  admin <- allocateParty "Admin"

  registryCid <- submit admin do
    createCmd CompanyRegistry with admin

  -- Add two companies
  _ <- submit admin do
    exerciseCmd registryCid AddCompany with
      employerName = "Alice Corp"
      companyName = "Acme Corp"
      country = "JP"

  _ <- submit admin do
    exerciseCmd registryCid AddCompany with
      employerName = "Bob Inc"
      companyName = "Tech Corp"
      country = "US"

  -- Query all CompanyProfile contracts
  companies <- query @CompanyProfile admin
  assertMsg "Should have 2 companies" (length companies == 2)

  return ()

testMultipleEmployees : Script ()
testMultipleEmployees = script do
  admin <- allocateParty "Admin"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"

  registryCid <- submit admin do
    createCmd CompanyRegistry with admin

  _ <- submit admin do
    exerciseCmd registryCid AddEmployee with
      companyName = "Acme Corp"
      employee = alice
      displayName = "Alice Smith"
      role = Some "Engineer"

  _ <- submit admin do
    exerciseCmd registryCid AddEmployee with
      companyName = "Acme Corp"
      employee = bob
      displayName = "Bob Jones"
      role = Some "Designer"

  -- Query all EmployeeRecord contracts
  employees <- query @EmployeeRecord admin
  assertMsg "Should have 2 employees" (length employees == 2)

  return ()
