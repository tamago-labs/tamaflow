module TamaFlow.Tests.AttendanceTest where

import DA.Time
import Daml.Script

import TamaFlow.Attendance.Types (BlockStatus(..))
import TamaFlow.Attendance.TimeBlock

testCheckIn : Script ()
testCheckIn = script do
  alice <- allocateParty "Alice"
  employer <- allocateParty "Employer"
  now <- getTime

  _ <- submit alice do
    createCmd TimeBlock with
      employee = alice
      employer
      blockStart = now
      blockEnd = addRelTime now (days 1)
      status = Open
      note = None

  return ()

testConfirmBlock : Script ()
testConfirmBlock = script do
  alice <- allocateParty "Alice"
  employer <- allocateParty "Employer"
  now <- getTime

  cid <- submit alice do
    createCmd TimeBlock with
      employee = alice
      employer
      blockStart = now
      blockEnd = addRelTime now (days 1)
      status = Open
      note = None

  let confirmTime = addRelTime now (days 2)
  _ <- submit employer do
    exerciseCmd cid ConfirmBlock with
      recordedAt = confirmTime

  return ()

testRejectBlock : Script ()
testRejectBlock = script do
  alice <- allocateParty "Alice"
  employer <- allocateParty "Employer"
  now <- getTime

  cid <- submit alice do
    createCmd TimeBlock with
      employee = alice
      employer
      blockStart = now
      blockEnd = addRelTime now (days 1)
      status = Open
      note = None

  let rejectTime = addRelTime now (days 2)
  _ <- submit employer do
    exerciseCmd cid RejectBlock with
      recordedAt = rejectTime
      reason = "Not approved"

  return ()

testMultipleBlocks : Script ()
testMultipleBlocks = script do
  alice <- allocateParty "Alice"
  employer <- allocateParty "Employer"
  now <- getTime

  _ <- submit alice do
    createCmd TimeBlock with
      employee = alice
      employer
      blockStart = now
      blockEnd = addRelTime now (days 1)
      status = Open
      note = None

  _ <- submit alice do
    createCmd TimeBlock with
      employee = alice
      employer
      blockStart = addRelTime now (days 1)
      blockEnd = addRelTime now (days 2)
      status = Open
      note = None

  _ <- submit alice do
    createCmd TimeBlock with
      employee = alice
      employer
      blockStart = addRelTime now (days 2)
      blockEnd = addRelTime now (days 3)
      status = Open
      note = None

  return ()
