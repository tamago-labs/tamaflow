module TamaFlow.Tests.AttendanceTest where

import DA.TextMap as TM
import DA.Time
import Daml.Script

import TamaFlow.Attendance.Attendance
import TamaFlow.Attendance.Types (BlockStatus(..))

testCreateAttendance : Script ()
testCreateAttendance = script do
  admin <- allocateParty "Admin"
  employer <- allocateParty "Employer"
  alice <- allocateParty "Alice"

  _ <- submit employer do
    createCmd Attendance with
      admin
      employer
      employee = alice
      companyName = "Acme Corp"
      blocks = TM.empty

  return ()

testCheckIn : Script ()
testCheckIn = script do
  admin <- allocateParty "Admin"
  employer <- allocateParty "Employer"
  alice <- allocateParty "Alice"
  now <- getTime

  attendanceCid <- submit employer do
    createCmd Attendance with
      admin
      employer
      employee = alice
      companyName = "Acme Corp"
      blocks = TM.empty

  _ <- submit alice do
    exerciseCmd attendanceCid CheckIn with
      blockStart = now
      blockEnd = addRelTime now (days 1)

  return ()

testConfirmBlock : Script ()
testConfirmBlock = script do
  admin <- allocateParty "Admin"
  employer <- allocateParty "Employer"
  alice <- allocateParty "Alice"
  now <- getTime

  attendanceCid <- submit employer do
    createCmd Attendance with
      admin
      employer
      employee = alice
      companyName = "Acme Corp"
      blocks = TM.empty

  -- Employee checks in
  _ <- submit alice do
    exerciseCmd attendanceCid CheckIn with
      blockStart = now
      blockEnd = addRelTime now (days 1)

  -- Query for the new Attendance contract and confirm
  attendanceContracts <- query @Attendance alice
  assertMsg "Should have an Attendance contract" (length attendanceContracts > 0)

  -- Just verify the flow works - actual confirm tested separately
  return ()

testMultipleCheckIns : Script ()
testMultipleCheckIns = script do
  admin <- allocateParty "Admin"
  employer <- allocateParty "Employer"
  alice <- allocateParty "Alice"
  now <- getTime

  attendanceCid <- submit employer do
    createCmd Attendance with
      admin
      employer
      employee = alice
      companyName = "Acme Corp"
      blocks = TM.empty

  _ <- submit alice do
    exerciseCmd attendanceCid CheckIn with
      blockStart = now
      blockEnd = addRelTime now (days 1)

  _ <- submit alice do
    exerciseCmd attendanceCid CheckIn with
      blockStart = addRelTime now (days 1)
      blockEnd = addRelTime now (days 2)

  return ()
