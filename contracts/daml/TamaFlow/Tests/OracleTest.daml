module TamaFlow.Tests.OracleTest where

import DA.TextMap as TM
import DA.Time
import Daml.Script

import TamaFlow.Oracle.PriceFeed

testCreatePriceFeed : Script ()
testCreatePriceFeed = script do
  admin <- allocateParty "Admin"
  now <- getTime

  let prices = TM.fromList
        [ ("USD", 1.0)
        , ("EUR", 1.08)
        , ("JPY", 0.0067)
        , ("THB", 0.028)
        ]

  _ <- submit admin do
    createCmd PriceFeed with
      admin
      prices
      updatedAt = now

  return ()

testUpdatePrices : Script ()
testUpdatePrices = script do
  admin <- allocateParty "Admin"
  now <- getTime

  feedCid <- submit admin do
    createCmd PriceFeed with
      admin
      prices = TM.fromList [("USD", 1.0), ("EUR", 1.08)]
      updatedAt = now

  let newPrices = TM.fromList [("USD", 1.0), ("EUR", 1.10), ("JPY", 0.007)]
  let later = addRelTime now (days 1)

  _ <- submit admin do
    exerciseCmd feedCid UpdatePrices with
      newPrices
      newUpdatedAt = later

  return ()

testSetSinglePrice : Script ()
testSetSinglePrice = script do
  admin <- allocateParty "Admin"
  now <- getTime

  feedCid <- submit admin do
    createCmd PriceFeed with
      admin
      prices = TM.fromList [("USD", 1.0)]
      updatedAt = now

  let later = addRelTime now (days 1)
  _ <- submit admin do
    exerciseCmd feedCid SetPrice with
      currency = "EUR"
      rate = 1.12
      newUpdatedAt = later

  return ()
