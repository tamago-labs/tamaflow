module Attendance.AttendanceRecord where

import Attendance.Types (BlockStatus(..))

-- | Immutable audit record created when a TimeBlock is confirmed or rejected.
template AttendanceRecord
  with
    employee : Party
    employer : Party
    blockStart : Time
    blockEnd : Time
    status : BlockStatus
    recordedAt : Time
  where
    signatory employee, employer
    observer employee, employer
